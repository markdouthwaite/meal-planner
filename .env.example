# Lightweight password gate for the app.
# If unset, the app falls back to the default password "meals".
# Set this in Vercel (Project Settings -> Environment Variables) and redeploy.
VITE_APP_PASSWORD=

# Supabase (required when connecting to a real backend)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
